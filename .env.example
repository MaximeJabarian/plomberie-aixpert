# Copier vers .env et remplir (ne pas commiter .env)

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

DEMO_ADMIN_SECRET=
# Utilisé par la page admin `/admin/demo` pour créer les liens tokenisés.
# Le prospect sans ce secret ne peut pas générer de lien.
# Tag optionnel pour distinguer plusieurs sites si vous partagez le même Supabase + le même onglet Sheet.
# Exemple: SITE_TAG=client-a  → Recipient devient "[client-a] Prospect"
# SITE_TAG=

# Par défaut, l’accueil et les pages marketing exigent une session démo encore valide (navigateur).
# Pour retrouver un site « public » en local (sans lien /demo/…) :
# VITE_DEMO_PUBLIC_BROWSING=1

# Logs détaillés démo dans le terminal (session, notify, Sheets) : 1 = activé en tout environnement
# DEMO_DEBUG=1

# Désactive les logs [demo] toujours visibles (stdout) — utile en prod si trop verbeux
# DEMO_QUIET=1

# Option A — tout service qui accepte un POST JSON (Zapier, n8n, Slack, etc.)
# DEMO_NOTIFY_WEBHOOK_URL=

# Option B — e-mail à la première ouverture (Resend : https://resend.com)
# RESEND_API_KEY=re_...
# DEMO_NOTIFY_EMAIL_TO=toi@example.com
# En production : expéditeur sur un domaine vérifié chez Resend, ex. :
# DEMO_NOTIFY_EMAIL_FROM=Basooka <demo@ton-domaine.com>

# Option C — journal dans un Google Sheet (Excel sur Drive)
# 1) Google Cloud : activer l’API « Google Sheets », créer un compte de service.
# 2) Sheets : partager le classeur avec l’e-mail …@….iam.gserviceaccount.com (Éditeur).
# 3) ID du classeur = segment entre /d/ et /edit dans l’URL du fichier.
# GOOGLE_SHEETS_SPREADSHEET_ID=
# Plage d’append = nom d’onglet exact + !A1 (ex. onglet « Detection ») — défaut code : Sheet1!A1
# GOOGLE_SHEETS_APPEND_RANGE=Detection!A1
# Ordre des colonnes après « First opening » (ligne append). Défaut = en-tête
# Date | Event | Recipient | First opening | Closing | Hash | Duration
# Ancien ordre (Hash puis Duration puis Closing vide) :
# GOOGLE_SHEETS_APPEND_LAYOUT=hash_duration_closing
# Colonnes pour retrouver la ligne et écrire Closing (déduits du layout si non définis)
# closing_hash_duration → Hash=F, Closing=E | hash_duration_closing → Hash=E, Closing=G
# GOOGLE_SHEETS_HASH_COLUMN=F
# GOOGLE_SHEETS_CLOSING_COLUMN=E
# Plage de recherche des lignes (lignes du tableau, hors en-tête)
# GOOGLE_SHEETS_DATA_START_ROW=2
# GOOGLE_SHEETS_DATA_END_ROW=5000
# Soit JSON du compte de service en base64 (recommandé sur Vercel) :
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
# Soit e-mail + clé privée (remplacer les retours ligne de la clé par \n dans .env) :
# GOOGLE_SERVICE_ACCOUNT_EMAIL=basooka@basooka.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY=a7ce9de0f51070b6bc011b24c68e81c0c7df3bbe
